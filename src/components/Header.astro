---
const base = import.meta.env.BASE_URL;
const navItems = [
  { label: '首页', href: `${base}/` },
  { label: '搜索', href: `${base}/search` },
  { label: '分类', href: `${base}/categories` },
  { label: '排行', href: `${base}/leaderboard` },
  { label: '关于', href: `${base}/about` },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href={`${base}/`} class="logo">每天一个开源项目</a>
    <nav class="nav">
      {navItems.map(item => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>
