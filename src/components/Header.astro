---
const navItems = [
  { label: '首页', href: '/' },
  { label: '搜索', href: '/search' },
  { label: '分类', href: '/categories' },
  { label: '排行', href: '/leaderboard' },
  { label: '关于', href: '/about' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">每天一个开源项目</a>
    <nav class="nav">
      {navItems.map(item => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>
