{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/session-start.js",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task|Agent|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/pre-tool-use.js",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "check|task-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/subagent-stop.js",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/user-prompt-submit.js",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
